{
  "expo": {
    "name": "Frequency",
    "slug": "frequency-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "frequency",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#102217"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.frequency.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#102217",
        "foregroundImage": "./assets/android-icon-foreground.png"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-web-browser",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "4e92e1e6-ee25-493d-b38e-ef354d9b4788"
      }
    }
  }
}
